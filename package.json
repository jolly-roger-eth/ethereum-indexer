{
  "name": "ethereum-indexer-monorepo",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "ipfs-gateway-emulator": "4.2.1-ipfs.2",
    "ldenv": "^0.5.0",
    "prettier": "^3.8.3",
    "pwag": "^0.4.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typedoc-vitepress-theme": "1.1.2",
    "typescript": "^6.0.3",
    "vitepress": "1.6.4",
    "zellij-launcher": "^0.0.1"
  },
  "scripts": {
    "prepare": "pnpm build",
    "preinstall": "npx only-allow pnpm",
    "cleandep": "rm -rf node_modules && pnpm -r exec rm -rf node_modules",
    "---------------------- PUBLISH --------------------": "",
    "prepublishOnly": "pnpm format:check && pnpm build",
    "release": "pnpm prepublishOnly && git push --all && pnpm changeset publish && git push --tags",
    "---------------------- FORMAT ----------------------": "",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "---------------------- DEV ----------------------": "",
    "dev": "ldenv pnpm --filter './packages/*' dev",
    "---------------------- TEST ----------------------": "",
    "test": "ldenv pnpm --filter './packages/*' test",
    "---------------------- BUILD ----------------------": "",
    "build": "ldenv pnpm --filter './packages/*' build",
    "build:examples": "ldenv pnpm --filter './examples/*' build",
    "---------------------- DOCUMENTATION ----------------------": "",
    "publish-typedoc": "typedoc --options typedoc.json ",
    "serve-docs": "ipfs-emulator --only -d docs -p 8080",
    "docs:dev": "pwag docs/public/icon.svg docs/web-config.json -o docs/public && npm run publish-typedoc && vitepress dev docs",
    "docs:build": "pwag docs/public/icon.svg docs/web-config.json -o docs/public && npm run publish-typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "---------------------- RUN FULL LOCAL SETUP ----------------------": "",
    "stop": "zellij kill-session $npm_package_name",
    "start:pnpm": "pnpm -r dev",
    "start": "zellij-launcher a $npm_package_name || zellij -n zellij.kdl -s $npm_package_name"
  }
}
